generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserType {
  INDIVIDUAL
  LEGAL_ENTITY
  ADMIN
}

enum PaymentMethod {
  CASH
  TRANSFER
  CARD
  CHECK
  OTHER
}

enum ExpenseBudgetGroup {
  ADMINISTRATION
  MAINTENANCE
  SECURITY
  INFRASTRUCTURE
  EXTRAORDINARY
  OTHER
}

enum LedgerStatus {
  OPEN
  PARTIAL
  PAID
  CANCELED
}

enum ChargeResponsibility {
  OWNER
  COMMERCE
}

enum ChargeGroupCanonicalKind {
  ORDINARY
  EXTRA_CONDO
  EXTRA_COMMERCE
  STC
  SANCTION
  COMODATO
  OTHER
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum PrivateAreaStatus {
  UNASSIGNED
  AVAILABLE
  SOLD
  UNDER_CONSTRUCTION
  RENTED
  DELINQUENT
}

enum ContactLinkTarget {
  SAME_TAB
  NEW_TAB
}

enum ProjectDocumentType {
  REGULATION
  INTERNAL_DOCUMENT
}

enum MigrationRunStatus {
  CREATED
  RUNNING
  FAILED
  COMPLETED
}

enum MigrationValidationSeverity {
  INFO
  WARNING
  ERROR
}

model Condominium {
  id        String   @id @default(uuid())
  legacyId  Int?     @unique
  name      String
  slug      String   @unique
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users                        User[]
  commerces                    Commerce[]
  userCommerces                UserCommerce[]
  privateAreas                 PrivateArea[]
  assignments                  ResidentAssignment[]
  rentals                      Rental[]
  chargeGroups                 ChargeGroup[]
  areaCharges                  AreaCharge[]
  charges                      Charge[]
  payments                     Payment[]
  incomes                      Income[]
  expenses                     Expense[]
  budgets                      Budget[]
  meetings                     Meeting[]
  notifications                Notification[]
  notificationCategories       NotificationCategory[]
  ticketDepartments            TicketDepartment[]
  tickets                      Ticket[]
  projects                     Project[]
  contacts                     ContactEntry[]
  structureGroups              CondominiumStructureGroup[]
  structurePositions           CondominiumStructurePosition[]
  structurePositionAssignments CondominiumStructurePositionAssignment[]
  paymentDetails               PaymentDetail[]
  paymentMethodCatalogs        PaymentMethodCatalog[]
  zoneCatalogs                 ZoneCatalog[]
  subzoneCatalogs              SubzoneCatalog[]
  landUseCatalogs              LandUseCatalog[]
  miscIncomeCatalogs           MiscIncomeCatalog[]
  budgetExpenseConcepts        BudgetExpenseConcept[]
  expenseConceptGroupMaps      ExpenseConceptGroupMap[]
  budgetGroups                 BudgetGroup[]
  sanctions                    SanctionCatalog[]
}

model User {
  id              String   @id @default(uuid())
  condominiumId   String
  legacyId        Int?
  userType        UserType @default(INDIVIDUAL)
  firstName       String?
  lastName        String?
  businessName    String?
  email           String?
  phone           String?
  requiresInvoice Boolean?
  passwordHash    String?
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  condominium                    Condominium                              @relation(fields: [condominiumId], references: [id])
  assignments                    ResidentAssignment[]
  commerces                      UserCommerce[]
  administrativeCommerces        Commerce[]                               @relation("CommerceAdministrativeContact")
  operativeCommerces             Commerce[]                               @relation("CommerceOperativeContact")
  rentalsAsAdministrativeContact Rental[]                                 @relation("RentalAdministrativeContact")
  rentalsAsOperativeContact      Rental[]                                 @relation("RentalOperativeContact")
  userRoles                      UserRole[]
  openedTickets                  Ticket[]
  structurePositionAssignments   CondominiumStructurePositionAssignment[]

  @@unique([condominiumId, legacyId])
  @@index([condominiumId])
  @@index([email])
}

model Role {
  id          String   @id @default(uuid())
  legacyId    Int?
  name        String
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  userRoles UserRole[]
}

model CondominiumStructureGroup {
  id            String   @id @default(uuid())
  condominiumId String
  legacyId      Int?
  name          String
  position      Int      @default(0)
  structureType Int      @default(0)
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  condominium Condominium                    @relation(fields: [condominiumId], references: [id])
  positions   CondominiumStructurePosition[]

  @@unique([condominiumId, legacyId])
  @@index([condominiumId, isActive, position])
}

model CondominiumStructurePosition {
  id            String   @id @default(uuid())
  condominiumId String
  groupId       String
  legacyId      Int?
  name          String
  quantity      Int      @default(1)
  isAlternate   Boolean  @default(false)
  sortOrder     Int      @default(0)
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  condominium Condominium                              @relation(fields: [condominiumId], references: [id])
  group       CondominiumStructureGroup                @relation(fields: [groupId], references: [id], onDelete: Cascade)
  assignments CondominiumStructurePositionAssignment[]

  @@unique([condominiumId, legacyId])
  @@index([condominiumId, isActive])
  @@index([groupId, isActive, sortOrder])
}

model CondominiumStructurePositionAssignment {
  id            String   @id @default(uuid())
  condominiumId String
  positionId    String
  userId        String
  isAlternate   Boolean  @default(false)
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  condominium Condominium                  @relation(fields: [condominiumId], references: [id])
  position    CondominiumStructurePosition @relation(fields: [positionId], references: [id], onDelete: Cascade)
  user        User                         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([positionId, userId, isAlternate])
  @@index([condominiumId, isActive])
  @@index([positionId, isAlternate, isActive])
  @@index([userId, isActive])
}

model UserRole {
  id        String   @id @default(uuid())
  userId    String
  roleId    String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
  role Role @relation(fields: [roleId], references: [id])

  @@unique([userId, roleId])
}

model UserCommerce {
  id            String   @id @default(uuid())
  condominiumId String
  userId        String
  commerceName  String
  sortOrder     Int      @default(0)
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  condominium Condominium @relation(fields: [condominiumId], references: [id])
  user        User        @relation(fields: [userId], references: [id])

  @@index([condominiumId])
  @@index([userId])
  @@index([userId, isActive])
}

model Commerce {
  id                          String   @id @default(uuid())
  condominiumId               String
  legacyId                    Int?
  name                        String?
  administrativeContactUserId String?
  operativeContactUserId      String?
  isActive                    Boolean  @default(true)
  createdAt                   DateTime @default(now())
  updatedAt                   DateTime @updatedAt

  condominium               Condominium @relation(fields: [condominiumId], references: [id])
  administrativeContactUser User?       @relation("CommerceAdministrativeContact", fields: [administrativeContactUserId], references: [id], onDelete: SetNull)
  operativeContactUser      User?       @relation("CommerceOperativeContact", fields: [operativeContactUserId], references: [id], onDelete: SetNull)
  rentals                   Rental[]

  @@unique([condominiumId, legacyId])
  @@index([condominiumId])
  @@index([administrativeContactUserId])
  @@index([operativeContactUserId])
}

model PrivateArea {
  id                     String            @id @default(uuid())
  condominiumId          String
  legacyId               Int?
  parentPrivateAreaId    String?
  sortOrder              Int               @default(0)
  code                   String?
  name                   String
  zone                   String?
  subzone                String?
  street                 String?
  useType                String?
  status                 PrivateAreaStatus @default(UNASSIGNED)
  isFusion               Boolean           @default(false)
  m2Original             Decimal?          @db.Decimal(12, 4)
  m2Apole                Decimal?          @db.Decimal(12, 4)
  m2Construction         Decimal?          @db.Decimal(12, 4)
  m2CommonArea           Decimal?          @db.Decimal(12, 4)
  m2ConstructionChildren Decimal?          @db.Decimal(12, 4)
  m2CommonAreaChildren   Decimal?          @db.Decimal(12, 4)
  indiviso               Decimal?          @db.Decimal(12, 6)
  vccc                   Decimal?          @db.Decimal(14, 6)
  isActive               Boolean           @default(true)
  createdAt              DateTime          @default(now())
  updatedAt              DateTime          @updatedAt

  condominium       Condominium          @relation(fields: [condominiumId], references: [id])
  parentPrivateArea PrivateArea?         @relation("PrivateAreaHierarchy", fields: [parentPrivateAreaId], references: [id], onDelete: SetNull)
  childPrivateAreas PrivateArea[]        @relation("PrivateAreaHierarchy")
  assignments       ResidentAssignment[]
  areaCharges       AreaCharge[]
  charges           Charge[]
  payments          Payment[]
  rentals           Rental[]
  attendances       Attendance[]
  tickets           Ticket[]
  incomes           Income[]

  @@unique([condominiumId, legacyId])
  @@index([condominiumId])
  @@index([parentPrivateAreaId])
  @@index([condominiumId, parentPrivateAreaId, sortOrder])
  @@index([status])
  @@index([isFusion])
}

model ResidentAssignment {
  id            String    @id @default(uuid())
  condominiumId String
  userId        String
  privateAreaId String
  roleName      String?
  startsAt      DateTime?
  endsAt        DateTime?
  isActive      Boolean   @default(true)

  condominium Condominium @relation(fields: [condominiumId], references: [id])
  user        User        @relation(fields: [userId], references: [id])
  privateArea PrivateArea @relation(fields: [privateAreaId], references: [id])

  @@index([condominiumId])
  @@index([userId])
  @@index([privateAreaId])
}

model Rental {
  id                          String    @id @default(uuid())
  condominiumId               String
  privateAreaId               String
  commerceId                  String?
  tenantName                  String?
  administrativeContactUserId String?
  operativeContactUserId      String?
  startsAt                    DateTime?
  endsAt                      DateTime?
  status                      String?
  notes                       String?

  condominium               Condominium @relation(fields: [condominiumId], references: [id])
  privateArea               PrivateArea @relation(fields: [privateAreaId], references: [id])
  commerce                  Commerce?   @relation(fields: [commerceId], references: [id], onDelete: SetNull)
  administrativeContactUser User?       @relation("RentalAdministrativeContact", fields: [administrativeContactUserId], references: [id], onDelete: SetNull)
  operativeContactUser      User?       @relation("RentalOperativeContact", fields: [operativeContactUserId], references: [id], onDelete: SetNull)
  charges                   Charge[]

  @@index([condominiumId])
  @@index([privateAreaId])
  @@index([commerceId])
  @@index([administrativeContactUserId])
  @@index([operativeContactUserId])
}

model ChargeGroup {
  id            String                   @id @default(uuid())
  condominiumId String
  legacyId      Int?
  name          String
  chargeType    String?
  kind          ChargeGroupCanonicalKind @default(OTHER)
  isActive      Boolean                  @default(true)

  condominium        Condominium         @relation(fields: [condominiumId], references: [id])
  areaCharges        AreaCharge[]
  charges            Charge[]
  paymentDetails     PaymentDetail[]
  incomes            Income[]
  miscIncomeCatalogs MiscIncomeCatalog[]

  @@unique([condominiumId, legacyId])
  @@index([condominiumId])
  @@index([condominiumId, kind, isActive])
}

model AreaCharge {
  id            String    @id @default(uuid())
  condominiumId String
  privateAreaId String
  chargeGroupId String
  amount        Decimal   @db.Decimal(14, 2)
  startsAt      DateTime?
  endsAt        DateTime?
  isActive      Boolean   @default(true)

  condominium Condominium @relation(fields: [condominiumId], references: [id])
  privateArea PrivateArea @relation(fields: [privateAreaId], references: [id])
  chargeGroup ChargeGroup @relation(fields: [chargeGroupId], references: [id])

  @@index([condominiumId])
  @@index([privateAreaId])
  @@index([chargeGroupId])
}

model Charge {
  id               String               @id @default(uuid())
  condominiumId    String
  privateAreaId    String
  chargeGroupId    String
  tenancyId        String?
  legacyId         Int?
  legacyStatusCode Int?
  concept          String?

  responsibility   ChargeResponsibility @default(OWNER)
  periodYear       Int
  periodMonth      Int
  amount           Decimal              @db.Decimal(14, 2)
  paidAmount       Decimal              @default(0) @db.Decimal(14, 2)
  interestAmount   Decimal              @default(0) @db.Decimal(14, 2)
  discountAmount   Decimal              @default(0) @db.Decimal(14, 2)
  isCollectible    Boolean              @default(true)
  dueDate          DateTime?
  status           LedgerStatus         @default(OPEN)
  createdAt        DateTime             @default(now())

  condominium Condominium         @relation(fields: [condominiumId], references: [id])
  privateArea PrivateArea         @relation(fields: [privateAreaId], references: [id])
  chargeGroup ChargeGroup         @relation(fields: [chargeGroupId], references: [id])
  tenancy     Rental?             @relation(fields: [tenancyId], references: [id], onDelete: SetNull)
  allocations PaymentAllocation[]

  @@unique([condominiumId, legacyId])
  @@index([condominiumId, periodYear, periodMonth])
  @@index([privateAreaId])
  @@index([privateAreaId, responsibility, periodYear, periodMonth])
  @@index([tenancyId])
  @@index([condominiumId, legacyStatusCode])
  @@index([responsibility])
}

model Payment {
  id                          String        @id @default(uuid())
  condominiumId               String
  legacyId                    Int?
  privateAreaId               String?
  isVisibleInFinancialSummary Boolean       @default(true)
  legacyStatusCode            Int?
  isLegacyActive              Boolean?
  legacyAreaCode              Int?
  legacyAreaIsActive          Boolean?
  paidAt                      DateTime
  amount                      Decimal       @db.Decimal(14, 2)
  method                      PaymentMethod
  reference                   String?
  notes                       String?
  createdAt                   DateTime      @default(now())

  condominium Condominium         @relation(fields: [condominiumId], references: [id])
  privateArea PrivateArea?        @relation(fields: [privateAreaId], references: [id], onDelete: SetNull)
  allocations PaymentAllocation[]
  details     PaymentDetail[]

  @@unique([condominiumId, legacyId])
  @@index([privateAreaId])
  @@index([condominiumId, isVisibleInFinancialSummary])
  @@index([condominiumId, legacyStatusCode])
  @@index([condominiumId, legacyAreaIsActive])
  @@index([condominiumId, paidAt])
}

model PaymentAllocation {
  id        String   @id @default(uuid())
  chargeId  String
  paymentId String
  amount    Decimal  @db.Decimal(14, 2)
  createdAt DateTime @default(now())

  charge  Charge  @relation(fields: [chargeId], references: [id])
  payment Payment @relation(fields: [paymentId], references: [id])

  @@unique([paymentId, chargeId])
  @@index([chargeId])
  @@index([paymentId])
}

model PaymentDetail {
  id            String   @id @default(uuid())
  condominiumId String
  legacyId      Int?
  paymentId     String
  chargeGroupId String?
  amount        Decimal  @db.Decimal(14, 2)
  creditBalance Decimal? @db.Decimal(14, 2)
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())

  condominium Condominium  @relation(fields: [condominiumId], references: [id])
  payment     Payment      @relation(fields: [paymentId], references: [id])
  chargeGroup ChargeGroup? @relation(fields: [chargeGroupId], references: [id])

  @@unique([condominiumId, legacyId])
  @@index([paymentId])
  @@index([chargeGroupId])
}

model PaymentMethodCatalog {
  id            String  @id @default(uuid())
  condominiumId String
  legacyId      Int?
  name          String
  isActive      Boolean @default(true)

  condominium Condominium @relation(fields: [condominiumId], references: [id])

  @@unique([condominiumId, legacyId])
}

model ZoneCatalog {
  id            String   @id @default(uuid())
  condominiumId String
  legacyId      Int?
  name          String
  initials      String?
  marketValue   Decimal? @db.Decimal(14, 2)
  weight        Decimal? @db.Decimal(12, 4)
  isActive      Boolean  @default(true)

  condominium Condominium      @relation(fields: [condominiumId], references: [id])
  subzones    SubzoneCatalog[]

  @@unique([condominiumId, legacyId])
}

model SubzoneCatalog {
  id            String  @id @default(uuid())
  condominiumId String
  legacyId      Int?
  zoneId        String?
  name          String
  initials      String?
  isActive      Boolean @default(true)

  condominium Condominium  @relation(fields: [condominiumId], references: [id])
  zone        ZoneCatalog? @relation(fields: [zoneId], references: [id], onDelete: SetNull)

  @@unique([condominiumId, legacyId])
  @@index([zoneId])
}

model LandUseCatalog {
  id            String   @id @default(uuid())
  condominiumId String
  legacyId      Int?
  name          String
  initials      String?
  order         Int?
  weight        Decimal? @db.Decimal(12, 4)
  percentage    Decimal? @db.Decimal(12, 6)
  isActive      Boolean  @default(true)

  condominium Condominium @relation(fields: [condominiumId], references: [id])

  @@unique([condominiumId, legacyId])
}

model MiscIncomeCatalog {
  id                  String  @id @default(uuid())
  condominiumId       String
  legacyId            Int?
  chargeGroupId       String?
  name                String
  legacyChargeGroupId Int?
  isActive            Boolean @default(true)
  order               Int     @default(0)

  condominium Condominium  @relation(fields: [condominiumId], references: [id])
  chargeGroup ChargeGroup? @relation(fields: [chargeGroupId], references: [id], onDelete: SetNull)
  incomes     Income[]

  @@unique([condominiumId, legacyId])
  @@index([chargeGroupId])
  @@index([condominiumId, isActive, chargeGroupId])
  @@index([condominiumId, isActive, legacyChargeGroupId])
}

model Income {
  id                  String         @id @default(uuid())
  condominiumId       String
  legacyId            Int?
  chargeGroupId       String?
  miscCatalogId       String?
  privateAreaId       String?
  date                DateTime
  concept             String
  amount              Decimal        @db.Decimal(14, 2)
  isActive            Boolean        @default(true)
  legacyChargeGroupId Int?
  legacyMiscCatalogId Int?
  legacyPrivateAreaId Int?
  isConfirmed         Boolean?
  paymentMethod       PaymentMethod?
  notes               String?
  receiptUrl          String?

  condominium Condominium        @relation(fields: [condominiumId], references: [id])
  chargeGroup ChargeGroup?       @relation(fields: [chargeGroupId], references: [id], onDelete: SetNull)
  miscCatalog MiscIncomeCatalog? @relation(fields: [miscCatalogId], references: [id], onDelete: SetNull)
  privateArea PrivateArea?       @relation(fields: [privateAreaId], references: [id], onDelete: SetNull)

  @@unique([condominiumId, legacyId])
  @@index([condominiumId, isActive, date])
  @@index([chargeGroupId])
  @@index([miscCatalogId])
  @@index([privateAreaId])
  @@index([condominiumId, legacyChargeGroupId])
  @@index([condominiumId, legacyMiscCatalogId, legacyChargeGroupId, isActive, date])
}

model Expense {
  id                    String         @id @default(uuid())
  condominiumId         String
  legacyId              Int?
  date                  DateTime
  concept               String
  amount                Decimal        @db.Decimal(14, 2)
  isActive              Boolean        @default(true)
  budgetConceptId       String?
  legacyBudgetConceptId Int?
  legacyReceipt         String?
  receiptUrl            String?
  legacyProjectName     String?
  projectName           String?
  paymentMethod         PaymentMethod?
  notes                 String?

  condominium   Condominium           @relation(fields: [condominiumId], references: [id])
  budgetConcept BudgetExpenseConcept? @relation(fields: [budgetConceptId], references: [id], onDelete: SetNull, onUpdate: Cascade)

  @@unique([condominiumId, legacyId])
  @@index([condominiumId, isActive, date])
  @@index([budgetConceptId])
  @@index([condominiumId, legacyBudgetConceptId])
}

enum BudgetStatus {
  OPEN
  CLOSED
}

model Budget {
  id            String       @id @default(uuid())
  condominiumId String
  legacyId      Int?
  year          Int
  name          String?
  isActive      Boolean      @default(true)
  status        BudgetStatus @default(OPEN)

  condominium             Condominium              @relation(fields: [condominiumId], references: [id])
  lines                   BudgetLine[]
  expenseConcepts         BudgetExpenseConcept[]
  expenseConceptGroupMaps ExpenseConceptGroupMap[]
  budgetGroups            BudgetGroup[]

  @@unique([condominiumId, year])
}

model BudgetGroup {
  id            String             @id @default(uuid())
  condominiumId String             @map("condominium_id")
  year          Int
  name          String
  isActive      Boolean            @default(true) @map("is_active")
  legacyId      Int?               @map("legacy_id")
  category      ExpenseBudgetGroup @default(OTHER)
  order         Int                @default(0)
  parentId      String?            @map("parent_id")

  condominium Condominium            @relation(fields: [condominiumId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  budget      Budget                 @relation(fields: [condominiumId, year], references: [condominiumId, year], onDelete: Restrict, onUpdate: Cascade)
  concepts    BudgetExpenseConcept[]
  parent      BudgetGroup?           @relation("BudgetGroupToParent", fields: [parentId], references: [id])
  children    BudgetGroup[]          @relation("BudgetGroupToParent")

  @@unique([condominiumId, year, legacyId])
  @@index([condominiumId, year, isActive])
  @@map("budget_group")
}

model BudgetExpenseConcept {
  id                    String             @id @default(uuid())
  condominiumId         String             @map("condominium_id")
  year                  Int
  name                  String
  budgetGroup           ExpenseBudgetGroup @map("group")
  budgetGroupId         String?            @map("budget_group_id")
  isActive              Boolean            @default(true) @map("is_active")
  legacyBudgetConceptId Int?               @map("legacy_budget_concept_id")
  source                String             @default("legacy_etl")
  order                 Int                @default(0)
  type                  String             @default("N/A") // N/A, Variable, Fijo
  createdAt             DateTime           @default(now()) @map("created_at")
  updatedAt             DateTime           @updatedAt @map("updated_at")

  condominium Condominium              @relation(fields: [condominiumId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  budget      Budget                   @relation(fields: [condominiumId, year], references: [condominiumId, year], onDelete: Restrict, onUpdate: Cascade)
  group       BudgetGroup?             @relation(fields: [budgetGroupId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  expenses    Expense[]
  budgetLines BudgetLine[]
  mappings    ExpenseConceptGroupMap[]

  @@unique([condominiumId, year, legacyBudgetConceptId])
  @@index([condominiumId, year, budgetGroup, isActive])
  @@index([condominiumId, year, isActive])
  @@index([condominiumId, year, name])
  @@map("budget_expense_concept")
}

model BudgetLine {
  id              String   @id @default(uuid())
  budgetId        String
  legacyId        Int?
  concept         String
  groupName       String?
  annualAmount    Decimal? @db.Decimal(14, 2)
  budgetConceptId String?

  budget        Budget                @relation(fields: [budgetId], references: [id])
  budgetConcept BudgetExpenseConcept? @relation(fields: [budgetConceptId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  months        BudgetMonth[]

  @@index([budgetId])
  @@index([budgetConceptId])
}

model BudgetMonth {
  id           String  @id @default(uuid())
  budgetLineId String
  month        Int
  amount       Decimal @db.Decimal(14, 2)

  budgetLine BudgetLine @relation(fields: [budgetLineId], references: [id])

  @@unique([budgetLineId, month])
}

model ExpenseConceptGroupMap {
  id                    BigInt   @id @default(autoincrement()) @db.BigInt
  condominiumId         String   @map("condominium_id")
  year                  Int
  legacyBudgetConceptId Int      @map("legacy_budget_concept_id")
  budgetConceptId       String?  @map("budget_concept_id")
  budgetGroupId         Int      @map("budget_group_id")
  isBudgetConceptActive Boolean  @default(true) @map("is_budget_concept_active")
  source                String   @default("legacy_etl")
  createdAt             DateTime @default(now()) @map("created_at")
  updatedAt             DateTime @updatedAt @map("updated_at")

  condominium   Condominium           @relation(fields: [condominiumId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  budget        Budget                @relation(fields: [condominiumId, year], references: [condominiumId, year], onDelete: Restrict, onUpdate: Cascade)
  budgetConcept BudgetExpenseConcept? @relation(fields: [budgetConceptId], references: [id], onDelete: SetNull, onUpdate: Cascade)

  @@unique([condominiumId, year, legacyBudgetConceptId])
  @@index([year, legacyBudgetConceptId])
  @@index([budgetConceptId])
  @@index([condominiumId, year, budgetGroupId])
  @@index([condominiumId, year, isBudgetConceptActive])
  @@map("expense_concept_group_map")
}

model Meeting {
  id            String   @id @default(uuid())
  condominiumId String
  legacyId      Int?
  title         String
  meetingType   String?
  status        String?
  createdAt     DateTime @default(now())

  condominium Condominium      @relation(fields: [condominiumId], references: [id])
  sessions    MeetingSession[]

  @@unique([condominiumId, legacyId])
  @@index([condominiumId])
}

model MeetingSession {
  id        String    @id @default(uuid())
  meetingId String
  startsAt  DateTime?
  endsAt    DateTime?
  status    String?

  meeting     Meeting      @relation(fields: [meetingId], references: [id])
  attendances Attendance[]
  votes       Vote[]

  @@index([meetingId])
}

model Attendance {
  id               String   @id @default(uuid())
  meetingSessionId String
  privateAreaId    String
  attendanceType   String?
  coefficient      Decimal? @db.Decimal(12, 6)

  meetingSession MeetingSession @relation(fields: [meetingSessionId], references: [id])
  privateArea    PrivateArea    @relation(fields: [privateAreaId], references: [id])

  @@index([meetingSessionId])
  @@index([privateAreaId])
}

model Vote {
  id               String  @id @default(uuid())
  meetingSessionId String
  topic            String
  voteType         String?
  votesFor         Int?
  votesAgainst     Int?
  votesAbstain     Int?

  meetingSession MeetingSession @relation(fields: [meetingSessionId], references: [id])

  @@index([meetingSessionId])
}

model Notification {
  id            String    @id @default(uuid())
  condominiumId String
  legacyId      Int?
  categoryId    String?
  title         String
  message       String
  category      String?
  sentAt        DateTime?
  validUntil    DateTime?
  imageUrl      String?
  imagePath     String?
  pdfUrl        String?
  pdfPath       String?

  condominium Condominium           @relation(fields: [condominiumId], references: [id])
  categoryRef NotificationCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  @@unique([condominiumId, legacyId])
  @@index([condominiumId])
  @@index([categoryId])
}

model NotificationCategory {
  id            String   @id @default(uuid())
  condominiumId String
  legacyId      Int?
  name          String
  color         String?
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  condominium   Condominium    @relation(fields: [condominiumId], references: [id])
  notifications Notification[]

  @@unique([condominiumId, legacyId])
  @@index([condominiumId, isActive])
}

model TicketDepartment {
  id            String   @id @default(uuid())
  condominiumId String
  legacyId      Int?
  name          String
  email         String
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  condominium Condominium @relation(fields: [condominiumId], references: [id])
  tickets     Ticket[]

  @@unique([condominiumId, legacyId])
  @@index([condominiumId, isActive])
}

model Ticket {
  id                String       @id @default(uuid())
  condominiumId     String
  legacyId          Int?
  departmentId      String?
  privateAreaId     String?
  openedById        String?
  title             String
  description       String?
  response          String?
  respondedAt       DateTime?
  responseImageUrl  String?
  responseImagePath String?
  responsePdfUrl    String?
  responsePdfPath   String?
  status            TicketStatus @default(OPEN)
  openedAt          DateTime     @default(now())
  closedAt          DateTime?
  isActive          Boolean      @default(true)

  condominium Condominium       @relation(fields: [condominiumId], references: [id])
  department  TicketDepartment? @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  privateArea PrivateArea?      @relation(fields: [privateAreaId], references: [id])
  openedBy    User?             @relation(fields: [openedById], references: [id])

  @@unique([condominiumId, legacyId])
  @@index([condominiumId])
  @@index([condominiumId, isActive])
  @@index([condominiumId, status])
  @@index([departmentId])
  @@index([privateAreaId])
}

model Project {
  id                  String    @id @default(uuid())
  condominiumId       String
  legacyId            Int?
  name                String
  initials            String?
  description         String?
  privacyNoticeText   String?
  startYear           Int?
  condominiumFormatId Int?
  totalM2             Decimal?  @db.Decimal(14, 4)
  totalApoles         Int?
  commonAreasM2       Decimal?  @db.Decimal(14, 4)
  condominiumLogoUrl  String?
  condominiumImageUrl String?
  footerLogoUrl       String?
  privacyNoticePdfUrl String?
  footerLeft          String?
  footerRight         String?
  developedBy         String?
  usesLandUseFormula  Boolean?
  hasVccc             Boolean?
  startsAt            DateTime?
  endsAt              DateTime?
  isActive            Boolean   @default(true)

  condominium Condominium       @relation(fields: [condominiumId], references: [id])
  documents   ProjectDocument[]

  @@unique([condominiumId, legacyId])
  @@index([condominiumId])
}

model ProjectDocument {
  id            String              @id @default(uuid())
  projectId     String
  legacyId      Int?
  fileName      String
  documentType  ProjectDocumentType @default(REGULATION)
  mimeType      String?
  sizeBytes     Int?
  storageBucket String
  storagePath   String
  checksum      String?
  isActive      Boolean             @default(true)
  uploadedAt    DateTime            @default(now())

  project Project @relation(fields: [projectId], references: [id])

  @@unique([projectId, legacyId])
  @@index([projectId])
  @@index([projectId, documentType])
  @@index([isActive])
}

model ContactType {
  id        String   @id @default(uuid())
  legacyId  Int?     @unique
  name      String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  contacts ContactEntry[]
}

model ContactEntry {
  id            String            @id @default(uuid())
  condominiumId String
  legacyId      Int?
  contactTypeId String
  name          String
  value         String
  linkUrl       String
  linkTarget    ContactLinkTarget @default(SAME_TAB)
  sortOrder     Int               @default(0)
  isActive      Boolean           @default(true)
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  condominium Condominium @relation(fields: [condominiumId], references: [id])
  contactType ContactType @relation(fields: [contactTypeId], references: [id])

  @@unique([condominiumId, legacyId])
  @@index([condominiumId, sortOrder])
  @@index([contactTypeId])
}

model MigrationRun {
  id             String             @id @default(uuid())
  name           String
  sourceSnapshot String
  dryRun         Boolean            @default(true)
  status         MigrationRunStatus @default(CREATED)
  startedAt      DateTime?
  completedAt    DateTime?
  createdAt      DateTime           @default(now())

  stagingRows       LegacyStagingRow[]
  idMaps            MigrationIdMap[]
  validationResults MigrationValidationResult[]

  @@index([status])
  @@index([createdAt])
}

model LegacyStagingRow {
  id             String    @id @default(uuid())
  runId          String
  legacyTable    String
  legacyId       Int
  payload        Json
  payloadHash    String
  extractedAt    DateTime  @default(now())
  transformedAt  DateTime?
  loadedAt       DateTime?
  promotedAt     DateTime?
  promotionError String?

  run MigrationRun @relation(fields: [runId], references: [id])

  @@unique([runId, legacyTable, legacyId])
  @@index([runId, legacyTable])
  @@index([runId, promotedAt])
}

model MigrationIdMap {
  id           String   @id @default(uuid())
  runId        String
  legacyTable  String
  legacyId     Int
  targetEntity String
  targetId     String
  createdAt    DateTime @default(now())

  run MigrationRun @relation(fields: [runId], references: [id])

  @@unique([runId, legacyTable, legacyId, targetEntity])
  @@index([runId, targetEntity])
}

model MigrationValidationResult {
  id           String                      @id @default(uuid())
  runId        String
  layer        String
  targetTable  String
  sourceCount  Int
  stagingCount Int
  finalCount   Int
  difference   Int
  severity     MigrationValidationSeverity @default(INFO)
  details      Json?
  createdAt    DateTime                    @default(now())

  run MigrationRun @relation(fields: [runId], references: [id])

  @@index([runId, layer])
  @@index([runId, severity])
}

model SanctionCatalog {
  id            String      @id @default(uuid())
  condominiumId String
  legacyId      Int?
  name          String
  article       String?
  isActive      Boolean     @default(true)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  condominium Condominium @relation(fields: [condominiumId], references: [id])

  @@unique([condominiumId, legacyId])
}
